<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <!--
      DisableMSBuildAssemblyCopyCheck was only needed for manual MSBuildLocator usage
      (Roslyn 4.8 and earlier). Roslyn 4.9+ uses a BuildHost subprocess that handles
      MSBuild discovery automatically, so this property is no longer required.
    -->
    <DisableMSBuildAssemblyCopyCheck>true</DisableMSBuildAssemblyCopyCheck>
    <AssemblyName>testwire</AssemblyName>
    <RootNamespace>TestWire</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>testwire</ToolCommandName>
    <PackageId>testwire</PackageId>
    <Version>0.3.0</Version>
    <Authors>Mazen Hassan</Authors>
    <Description>Generates xUnit/NUnit test stubs for ASP.NET Core controllers using Roslyn. Reads your actual controller structure and produces compilable test files with mocked dependencies.</Description>
    <PackageProjectUrl>https://github.com/mazensakr05/TestWire</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mazensakr05/TestWire</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>testing;test-generation;roslyn;aspnetcore;xunit;moq;codegen;cli</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageReleaseNotes>https://github.com/mazensakr05/TestWire/blob/main/CHANGELOG.md</PackageReleaseNotes>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Roslyn 4.9+ introduced a BuildHost subprocess architecture that discovers MSBuild
      automatically from the installed .NET SDK without requiring manual MSBuildLocator
      calls. This works portably across all machines regardless of SDK version.

      We keep Microsoft.Build.Locator as a fallback registration path for edge cases.
      The transitive Microsoft.Build.* packages no longer need ExcludeAssets since
      Roslyn's BuildHost loads them out-of-process.
    -->
    <PackageReference Include="Microsoft.Build.Locator" Version="1.7.8" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.13.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="4.13.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="4.13.0" />
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
  </ItemGroup>

</Project>
