# ==========================================
# Enhanced .gitignore for modern .NET Projects
# Targets modern C# / ASP.NET Core, Rider,
# VS Code, Visual Studio, and multi-OS environments.
# ==========================================

# ------------------------------------------
# Build & Output Artifacts
# ------------------------------------------
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
publish/
out/

# ------------------------------------------
# .NET Core & Dependency Packages
# ------------------------------------------
project.lock.json
project.fragment.lock.json
artifacts/
*.nupkg
*.snupkg
**/[Pp]ackages/*
packages/
.paket/

# ------------------------------------------
# MSBuild & Tooling Temporary Files
# ------------------------------------------
*.binlog
*.suo
*.user
*.userosscache
*.sln.docstates
*.db-shm
*.db-wal
.clickonce/
ClientBin/
Generated_Files/

# ------------------------------------------
# Testing & Code Coverage
# ------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml
*.trx
*.html
CodeCoverage/
.openCover/
dotCover/

# ------------------------------------------
# Local Configurations & Secrets
# ------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
secrets.json
appsettings.local.json
*.user.json

# ------------------------------------------
# JetBrains Rider & IntelliJ IDEA
# ------------------------------------------
.idea/
*.sln.iml
*.patch
*.diff

# ------------------------------------------
# Visual Studio Code
# ------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/snippets/
.history/
*.code-workspace

# ------------------------------------------
# Visual Studio (Windows/Mac)
# ------------------------------------------
.vs/
*.userprefs
MonoAndroid/
MonoTouch/

# ------------------------------------------
# OS-Specific Files
# ------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.trash

# ------------------------------------------
# AI and Tool-specific
# ------------------------------------------
GEMINI.md
.gemini/
.gemini_security/

